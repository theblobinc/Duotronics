        "word": []
      },
      "op": "normalize_family_word"
    },
    {
      "case_id": "simple.invalid_digit",
      "expect": {
        "equals": {
          "failure_code": "invalid_digit",
          "invalid_digit": "h9",
          "policy_action": "reject"
        }
      },
      "given": {
        "family_id": "hex6",
        "word": [
          "h9"
        ]
      },
      "op": "normalize_family_word"
    },
    {
      "case_id": "simple.schema_mismatch",
      "expect": {
        "equals": {
