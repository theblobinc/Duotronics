{
  "cases": [
    {
      "case_id": "simple.hex6.h1h4",
      "expect": {
        "equals": {
          "canonical_storage": "family:hex6 schema_version:dpfc-family@v5.6 digits:1 4",
          "core_magnitude": "mu_10",
          "failure_code": null,
          "lookup_allowed": true,
          "normalizer_version": "simple-bijective-word-normalizer@v1",
          "policy_action": "normal"
        }
      },
      "given": {
        "family_id": "hex6",
        "word": [
          "h1",
          "h4"
        ]
      },
      "op": "normalize_family_word"
    },
    {
      "case_id": "simple.unknown_family",
      "expect": {
        "equals": {
          "failure_code": "unknown_family",
          "lookup_allowed": false,
          "policy_action": "family_bypass"
        }
      },
      "given": {
        "family_id": "nope",
        "word": [
          "x"
        ]
      },
      "op": "normalize_family_word"
    },
    {
      "case_id": "simple.empty_word",
      "expect": {
