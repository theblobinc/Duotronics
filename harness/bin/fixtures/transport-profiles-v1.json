{
  "cases": [
    {
      "case_id": "dbp.minsafe.happy_path",
      "expect": {
        "equals": {
          "policy_mode": "normal",
          "semantic_decode_allowed": true,
          "state_reached": "semantic_decoder_allowed",
          "trusted_memory_write": false
        },
        "must_not_emit_audit": [
          "transport_rejected"
        ]
      },
      "given": {
        "frame": {
          "integrity_check": "passed",
          "payload_kind": "witness8",
          "profile_id": "dbp-minsafe@v1",
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    },
    {
      "case_id": "dbp.invalid_shape",
      "expect": {
        "equals": {
          "failure_code": "frame_shape_invalid",
          "policy_mode": "transport_bypass",
          "semantic_decode_allowed": false
        },
        "must_emit_audit": [
          "transport_rejected"
        ]
      },
      "given": {
        "frame": {
          "shape_valid": false
        }
      },
      "op": "dbp_ingress"
    },
    {
      "case_id": "dbp.unknown_profile",
      "expect": {
        "equals": {
          "failure_code": "unknown_transport_profile",
          "policy_mode": "transport_bypass"
        },
        "must_emit_audit": [
          "transport_rejected"
        ]
      },
      "given": {
        "frame": {
          "integrity_check": "passed",
          "profile_id": "dbp-future@v1",
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    },
    {
      "case_id": "dbp.minsafe.integrity_failed",
      "expect": {
        "equals": {
          "failure_code": "transport_integrity_failed",
          "policy_mode": "transport_bypass"
        },
        "must_emit_audit": [
          "transport_rejected"
        ]
      },
      "given": {
        "frame": {
          "integrity_check": "failed",
          "profile_id": "dbp-minsafe@v1",
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    },
    {
      "case_id": "dbp.strict.requires_sequence",
      "expect": {
        "equals": {
          "failure_code": "transport_sequence_missing",
          "policy_mode": "transport_bypass"
        }
      },
      "given": {
        "frame": {
          "integrity_check": "passed",
          "profile_id": "dbp-strict@v1",
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    },
    {
      "case_id": "dbp.replay_window_rejected",
      "expect": {
        "equals": {
          "failure_code": "transport_replay_window",
          "policy_mode": "transport_bypass"
        },
        "must_emit_audit": [
          "transport_rejected"
        ]
      },
      "given": {
        "frame": {
          "integrity_check": "passed",
          "profile_id": "dbp-minsafe@v1",
          "replay_token_seen": true,
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    },
    {
      "case_id": "ingress.composite.witness8_rejected_at_transport",
      "expect": {
        "key_falsy": [
          "decoded",
          "canonical"
        ]
      },
      "given": {
        "frame": {
          "profile_id": "dbp-minsafe@v1",
          "shape_valid": false
        }
      },
      "op": "ingress_frame"
    },
    {
      "case_id": "ingress.composite.wsb2_through_minsafe",
      "expect": {
        "key_truthy": [
          "transport",
          "decoded"
        ]
      },
      "given": {
        "frame": {
          "integrity_check": "passed",
          "payload": {
            "rows": [
              {
                "active": false,
                "lane": 1
              },
              {
                "active": true,
                "lane": 2,
                "witness8": [
                  0.25,
                  0.6,
                  1.0,
                  0.5,
                  1.0,
                  0.25,
                  1.0,
                  1.0
                ]
              }
            ]
          },
          "payload_kind": "wsb2",
          "profile_id": "dbp-minsafe@v1",
          "shape_valid": true
        }
      },
      "op": "ingress_frame"
    },
    {
      "case_id": "registry.transport.minsafe",
      "expect": {
        "equals": {
          "declares_numeric_zero": false,
          "profile_id": "dbp-minsafe",
          "requires_replay_key": true
        }
      },
      "given": {
        "profile_id": "dbp-minsafe",
        "version": "v1"
      },
      "op": "resolve_transport"
    },
    {
      "case_id": "registry.transport.strict",
      "expect": {
        "equals": {
          "declares_numeric_zero": true
        }
      },
      "given": {
        "profile_id": "dbp-strict",
        "version": "v1"
      },
      "op": "resolve_transport"
    }
  ],
  "description": "DBP transport state machine \u2014 shape \u2192 profile \u2192 integrity \u2192 sequence \u2192\nreplay. Failures must surface explicit failure codes and never reach\ntrusted memory (Transport \u00a75, \u00a77).\n",
  "pack_id": "transport-profiles-v1"
}
