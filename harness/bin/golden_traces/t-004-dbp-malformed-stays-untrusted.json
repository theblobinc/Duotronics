{
  "description": "Malformed shape, then unknown profile, then integrity failure \u2014 every\nrejection must surface a transport_bypass policy mode and never produce\na writeable canonical key.\n",
  "steps": [
    {
      "expect": {
        "equals": {
          "failure_code": "frame_shape_invalid",
          "policy_mode": "transport_bypass"
        }
      },
      "given": {
        "frame": {
          "shape_valid": false
        }
      },
      "op": "dbp_ingress"
    },
    {
      "expect": {
        "equals": {
          "failure_code": "unknown_transport_profile"
        }
      },
      "given": {
        "frame": {
          "integrity_check": "passed",
          "profile_id": "dbp-future@v1",
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    },
    {
      "expect": {
        "equals": {
          "failure_code": "transport_integrity_failed"
        }
      },
      "given": {
        "frame": {
          "integrity_check": "failed",
          "profile_id": "dbp-minsafe@v1",
          "shape_valid": true
        }
      },
      "op": "dbp_ingress"
    }
  ],
  "trace_id": "t-004-dbp-malformed-stays-untrusted"
}
